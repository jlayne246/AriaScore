{
  "build": {
    "production": {
      "developmentClient": false,
      "distribution": "store",
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_BUILD_MODE": "production"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    },

    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_BUILD_MODE": "preview",
        "APP_VERSION_NAME": "1.1.0",
        "APP_VERSION_CODE": "11004",
        "PREVIEW_BUILD_NUMBER": "4"
      },
      "android": {
        "gradleCommand": ":app:assemblePreview"
      },
      "ios": {
        "simulator": false
      }
    },

    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_BUILD_MODE": "development"
      }
    }
  }
}